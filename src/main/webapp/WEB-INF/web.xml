<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>FindMyProfessors</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.fmp.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.fmp.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.fmp.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SearchCoursesServlet</servlet-name>
        <servlet-class>com.fmp.servlet.SearchCoursesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchCoursesServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>
    
	<servlet>
    	<servlet-name>AdminPanelServlet</servlet-name>
    	<servlet-class>com.fmp.servlet.AdminPanelServlet</servlet-class>
	</servlet>

	<servlet-mapping>
	    <servlet-name>AdminPanelServlet</servlet-name>
	    <url-pattern>/adminPanel</url-pattern>
	</servlet-mapping>
    
    <servlet>
        <servlet-name>AddCourseServlet</servlet-name>
        <servlet-class>com.fmp.servlet.AddCourseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddCourseServlet</servlet-name>
        <url-pattern>/addCourse</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <servlet-class>com.fmp.servlet.ChangePasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <url-pattern>/changePassword</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UploadTranscriptServlet</servlet-name>
        <servlet-class>com.fmp.servlet.UploadTranscriptServlet</servlet-class>
        <multipart-config>
            <max-file-size>5242880</max-file-size>
            <max-request-size>5242880</max-request-size>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>UploadTranscriptServlet</servlet-name>
        <url-pattern>/uploadTranscript</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteAccountServlet</servlet-name>
        <servlet-class>com.fmp.servlet.DeleteAccountServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteAccountServlet</servlet-name>
        <url-pattern>/deleteAccount</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MyCoursesServlet</servlet-name>
        <servlet-class>com.fmp.servlet.MyCoursesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MyCoursesServlet</servlet-name>
        <url-pattern>/myCourses</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RemoveCourseServlet</servlet-name>
        <servlet-class>com.fmp.servlet.RemoveCourseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RemoveCourseServlet</servlet-name>
        <url-pattern>/removeCourse</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BuildScheduleServlet</servlet-name>
        <servlet-class>com.fmp.servlet.BuildScheduleServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BuildScheduleServlet</servlet-name>
        <url-pattern>/buildSchedule</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
